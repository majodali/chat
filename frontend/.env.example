# For LOCAL development only (`npm run dev`).
# In production the deployed site serves /config.json with the real URLs, so you
# don't need this file for deploys. Copy to frontend/.env.local to use locally,
# pointing at a deployed backend:
VITE_API_URL=https://xxxx.execute-api.us-east-1.amazonaws.com
VITE_WS_URL=wss://yyyy.execute-api.us-east-1.amazonaws.com/prod
