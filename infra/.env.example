# Copy this file to infra/.env and fill in your values, then run `npm run deploy`.

# ---- Where the app is hosted ----
# The chat app is deployed INTO your EXISTING S3 bucket that already serves
# liddle.cloud, under a sub-folder. Nothing else in the bucket is touched.
SITE_BUCKET_NAME=liddle.cloud
SITE_PATH_PREFIX=chat
# Public URL (used only for the deploy output). Defaults to
# http://<bucket>/<prefix> if left unset.
SITE_BASE_URL=http://liddle.cloud/chat

# ---- First admin account (seeded on deploy) ----
# You will log in with these to create everyone else's accounts.
ADMIN_USERNAME=parent
ADMIN_PASSWORD=change-me-to-something-strong

# ---- AWS target ----
# Use the same region your liddle.cloud bucket + resources live in. CDK also
# reads CDK_DEFAULT_ACCOUNT/REGION from your AWS CLI credentials automatically.
CDK_DEFAULT_REGION=us-east-1
