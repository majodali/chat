# Copy this file to infra/.env and fill in your values, then run `npm run deploy`.

# ---- Custom domain (optional) ----
# Your domain. Leave BLANK for the first deploy to just use the CloudFront URL,
# then set it once your Route53 hosted zone is ready and deploy again.
DOMAIN_NAME=liddle.cloud
# Also serve www.liddle.cloud ? (true/false)
INCLUDE_WWW=false

# ---- First admin account (seeded on deploy) ----
# You will log in with these to create everyone else's accounts.
ADMIN_USERNAME=parent
ADMIN_PASSWORD=change-me-to-something-strong

# ---- AWS target ----
# Region MUST be us-east-1 when using a custom domain (CloudFront requires its
# ACM certificate in us-east-1). CDK also reads CDK_DEFAULT_ACCOUNT/REGION from
# your AWS CLI credentials automatically.
CDK_DEFAULT_REGION=us-east-1
